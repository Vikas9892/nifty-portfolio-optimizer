# ── Test environment ──────────────────────────────────────────────────────────
# Loaded by pytest via the CI env: block in ci.yml.
# Tests use a tmp_path SQLite file — DATABASE_URL here is ignored by conftest.

ENVIRONMENT=test

APP_NAME="Nifty Portfolio Optimizer"

JWT_SECRET_KEY=ci-test-secret-key-not-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# conftest.py patches the engine; this value is a fallback
DATABASE_URL=sqlite:///data/test.db

# Redis disabled in tests
REDIS_URL=

CORS_ORIGINS=["http://localhost:3000"]
